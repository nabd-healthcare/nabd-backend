# ══════════════════════════════════════════════
# عينات اختبار جاهزة للباك اند
# POST http://localhost:8000/diagnose
# ══════════════════════════════════════════════

# ── Case 1: التهاب رئوي (Pneumonia) ──────────
POST /diagnose
{
  "evidence_codes": ["E_91", "E_167", "E_28", "E_38", "E_119"],
  "age": 55,
  "sex": "M"
}

# Expected:
# primary_diagnosis.disease_en = "Pneumonia"
# primary_diagnosis.disease_ar = "الالتهاب الرئوي"
# confidence ≈ 80%+


# ── Case 2: إنفلونزا (Influenza) ─────────────
POST /diagnose
{
  "evidence_codes": ["E_91", "E_167", "E_119", "E_149", "E_103"],
  "age": 35,
  "sex": "M"
}

# Expected:
# primary_diagnosis.disease_en = "Influenza"
# primary_diagnosis.disease_ar = "الإنفلونزا الموسمية"


# ── Case 3: أزمة قلبية (NSTEMI/STEMI) ────────
POST /diagnose
{
  "evidence_codes": ["E_55_@_V_101", "E_28", "E_9", "E_103", "E_232"],
  "age": 62,
  "sex": "M"
}

# Expected:
# primary_diagnosis.disease_en = "Possible NSTEMI / STEMI"
# primary_diagnosis.disease_ar = "احتمال احتشاء عضلة القلب"


# ── Case 4: ربو حاد (Asthma) ─────────────────
POST /diagnose
{
  "evidence_codes": ["E_28", "E_167", "E_251", "E_103"],
  "age": 30,
  "sex": "F"
}

# Expected:
# primary_diagnosis.disease_en = "Bronchospasm / acute asthma exacerbation"
# primary_diagnosis.disease_ar = "نوبة الربو الحادة"


# ── Case 5: سل رئوي (Tuberculosis) ───────────
POST /diagnose
{
  "evidence_codes": ["E_167", "E_91", "E_149", "E_213", "E_28"],
  "age": 40,
  "sex": "M"
}

# Expected:
# primary_diagnosis.disease_en = "Tuberculosis"
# primary_diagnosis.disease_ar = "السل الرئوي"


# ══════════════════════════════════════════════
# عينات اختبار جاهزة باللغة الإنجليزية (Symptoms Text - From Dataset)
# ══════════════════════════════════════════════

# ── Case 6: السل الرئوي (Tuberculosis) ──────────
# Symptoms from Dataset: Cough (E_201), Coughing up blood (E_45), Dyspnea (E_66), Fever (E_91), Weight loss (E_162)
POST http://localhost:5161/api/Diagnosis/analyze
Content-Type: application/json

{
  "patientId": "pt-123",
  "symptomsText": "fever, chronic cough, coughing up blood, shortness of breath, involuntary weight loss",
  "age": 40,
  "sex": "M"
}

###

# ── Case 7: ارتجاع المريء (GERD) ────────────
# Symptoms from Dataset: Heartburn/Acid Reflux (E_173), Cough (E_201), Worse after eating (E_215), Chest pain (E_55)
POST http://localhost:5161/api/Diagnosis/analyze
Content-Type: application/json

{
  "patientId": "pt-124",
  "symptomsText": "burning sensation in stomach, chest pain, cough, symptoms worse after eating",
  "age": 35,
  "sex": "F"
}

###

# ── Case 8: الصداع العنقودي (Cluster headache) ──
# Symptoms from Dataset: Head Pain (E_55), Excessive tears (E_127), Nasal congestion/Runny nose (E_181)
POST http://localhost:5161/api/Diagnosis/analyze
Content-Type: application/json

{
  "patientId": "pt-125",
  "symptomsText": "severe headache, excessive tears, runny nose",
  "age": 28,
  "sex": "M"
}
